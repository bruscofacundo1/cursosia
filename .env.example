# Odoo instance (One App Free for now; same vars work for Community self-hosted later)
ODOO_URL=https://TUBASE.odoo.com
ODOO_DB=TUBASE
ODOO_USER=tu@email.com
ODOO_API_KEY=tu_api_key_de_odoo

# Anthropic (default provider)
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6   # optional override

# Temporary dev fallback while there is no Anthropic key: set LLM_PROVIDER=gemini
# and provide GEMINI_API_KEY. Remove/comment LLM_PROVIDER to switch back to Claude.
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash    # optional override
